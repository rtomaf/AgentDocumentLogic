{
  "id": "agent-document-logic",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "openaiApiKey": {
        "type": "string",
        "description": "OpenAI API key (falls back to OPENAI_API_KEY env var)"
      },
      "stateDir": {
        "type": "string",
        "description": "Directory for operation state persistence",
        "default": "./state"
      },
      "defaultTokenBudget": {
        "type": "number",
        "description": "Token budget per processing window",
        "default": 50000
      },
      "defaultOverlapTokens": {
        "type": "number",
        "description": "Overlap context tokens at chunk boundaries",
        "default": 500
      },
      "maxRetries": {
        "type": "number",
        "description": "Maximum retry attempts per failed task",
        "default": 3
      },
      "reasoningEffort": {
        "type": "string",
        "enum": ["low", "medium", "high"],
        "description": "GPT-5.4 reasoning effort level",
        "default": "medium"
      }
    }
  },
  "skills": [
    { "id": "document-agent", "path": "skills/document-agent" }
  ]
}
